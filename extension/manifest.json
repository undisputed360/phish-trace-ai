{
  "manifest_version": 3,
  "name": "PhishTrace AI",
  "version": "1.0.0",
  "description": "Detect phishing URLs in real-time with AI explanations",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
